rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: vehicles
    // Fields: plateNumber, ownerName, phoneNumber, fcExpiry, permitExpiry, insuranceExpiry, nationalPermitExpiry, createdAt, lastReminderSent, lastSync
    //
    // Collection: tax_records
    // Fields: plateNumber, ownerName, phoneNumber, taxType, taxAmount, gt, information, paidDate, inDate, taxExpiry, createdAt
    //
    // Collection: billing_records
    // Fields: date, customerName, phoneNumber, vehicleNumber, serviceDescription, amount, paidAmount, pendingAmount, paymentStatus, paymentMode, createdAt
    //
    // Collection: settings/vahan_config
    // Fields: expiryReminderDays
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isValidVehicle(data) {
      return data.keys().hasAll(['plateNumber', 'ownerName', 'phoneNumber']) &&
             data.plateNumber is string && data.plateNumber.size() > 0 && data.plateNumber.size() < 20 &&
             data.ownerName is string && data.ownerName.size() > 0 && data.ownerName.size() < 100 &&
             data.phoneNumber is string && data.phoneNumber.size() >= 10 && data.phoneNumber.size() <= 15;
    }

    function isValidTaxRecord(data) {
      return data.keys().hasAll(['plateNumber', 'ownerName', 'taxAmount']) &&
             data.plateNumber is string && data.plateNumber.size() < 20 &&
             data.ownerName is string && data.ownerName.size() < 100;
    }

    function isValidBillingRecord(data) {
      return data.keys().hasAll(['date', 'customerName', 'vehicleNumber', 'amount']) &&
             data.customerName is string && data.customerName.size() < 100 &&
             data.vehicleNumber is string && data.vehicleNumber.size() < 20 &&
             data.amount is number;
    }

    match /_connection_test_/ping {
      allow read, write: if true;
    }

    match /vehicles/{vehicleId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && isValidVehicle(request.resource.data);
      allow delete: if isAuthenticated();
    }

    match /tax_records/{taxId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && isValidTaxRecord(request.resource.data);
      allow delete: if isAuthenticated();
    }

    match /billing_records/{billingId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && isValidBillingRecord(request.resource.data);
      allow delete: if isAuthenticated();
    }

    match /settings/vahan_config {
      allow read: if true;
      allow write: if isAuthenticated();
    }
  }
}
