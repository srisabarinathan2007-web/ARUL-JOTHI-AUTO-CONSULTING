{
  "entities": {
    "Vehicle": {
      "title": "Vehicle",
      "description": "Represents a vehicle and its document expiry dates.",
      "type": "object",
      "properties": {
        "plateNumber": { "type": "string", "description": "Registration number of the vehicle" },
        "ownerName": { "type": "string", "description": "Name of the vehicle owner" },
        "phoneNumber": { "type": "string", "description": "Contact number" },
        "fcExpiry": { "type": "string", "format": "date", "description": "FC expiry date" },
        "permitExpiry": { "type": "string", "format": "date", "description": "Permit expiry date" },
        "insuranceExpiry": { "type": "string", "format": "date", "description": "Insurance expiry date" },
        "nationalPermitExpiry": { "type": "string", "format": "date", "description": "National Permit expiry date" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastReminderSent": { "type": "string", "format": "date-time" },
        "lastSync": { "type": "string", "format": "date-time" }
      },
      "required": ["plateNumber", "ownerName", "phoneNumber"]
    },
    "TaxRecord": {
      "title": "TaxRecord",
      "description": "Represents a tax payment record for a vehicle.",
      "type": "object",
      "properties": {
        "plateNumber": { "type": "string" },
        "ownerName": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "taxType": { "type": "string" },
        "taxAmount": { "type": "string" },
        "gt": { "type": "string" },
        "information": { "type": "string" },
        "paidDate": { "type": "string", "format": "date" },
        "inDate": { "type": "string", "format": "date" },
        "taxExpiry": { "type": "string", "format": "date" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["plateNumber", "ownerName", "taxAmount"]
    },
    "BillingRecord": {
      "title": "BillingRecord",
      "description": "Represents a service billing/account record.",
      "type": "object",
      "properties": {
        "date": { "type": "string", "format": "date" },
        "customerName": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "vehicleNumber": { "type": "string" },
        "serviceDescription": { "type": "string" },
        "amount": { "type": "number" },
        "paidAmount": { "type": "number" },
        "pendingAmount": { "type": "number" },
        "paymentStatus": { "type": "string", "enum": ["Paid", "Pending", "Partial"] },
        "paymentMode": { "type": "string", "enum": ["Cash", "UPI", "Bank Transfer", "Cheque"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["date", "customerName", "vehicleNumber", "amount"]
    },
    "VahanConfig": {
      "title": "VahanConfig",
      "description": "System settings for the application.",
      "type": "object",
      "properties": {
        "expiryReminderDays": { "type": "number" }
      }
    }
  },
  "firestore": {
    "/vehicles/{vehicleId}": {
      "schema": "Vehicle",
      "description": "Collection of all vehicles."
    },
    "/tax_records/{taxId}": {
      "schema": "TaxRecord",
      "description": "Collection of tax payment history."
    },
    "/billing_records/{billingId}": {
      "schema": "BillingRecord",
      "description": "Collection of billing and accounting records."
    },
    "/settings/vahan_config": {
      "schema": "VahanConfig",
      "description": "Global system configuration."
    }
  }
}
