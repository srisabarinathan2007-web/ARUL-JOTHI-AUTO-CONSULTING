rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: vehicles
    // Document ID: auto-generated
    // Fields:
    //   - plateNumber: string (required, TN-XX-XXXX format)
    //   - ownerName: string (required, < 100 chars)
    //   - phoneNumber: string (required, 10-15 chars)
    //   - fcExpiry: string (optional, ISO date)
    //   - permitExpiry: string (optional, ISO date)
    //   - insuranceExpiry: string (optional, ISO date)
    //   - nationalPermitExpiry: string (optional, ISO date)
    //   - lastReminderSent: string (optional, ISO date-time)
    //
    // Collection: tax_records
    // Document ID: auto-generated
    // Fields:
    //   - plateNumber: string (required)
    //   - ownerName: string (required)
    //   - phoneNumber: string (required)
    //   - taxExpiry: string (required, ISO date)
    //   - lastReminderSent: string (optional, ISO date-time)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isValidVehicle(data) {
      return data.keys().hasAll(['plateNumber', 'ownerName', 'phoneNumber']) &&
             data.plateNumber is string && data.plateNumber.size() > 0 && data.plateNumber.size() < 20 &&
             data.ownerName is string && data.ownerName.size() > 0 && data.ownerName.size() < 100 &&
             data.phoneNumber is string && data.phoneNumber.size() >= 10 && data.phoneNumber.size() <= 15 &&
             (!('fcExpiry' in data) || data.fcExpiry is string) &&
             (!('permitExpiry' in data) || data.permitExpiry is string) &&
             (!('insuranceExpiry' in data) || data.insuranceExpiry is string) &&
             (!('nationalPermitExpiry' in data) || data.nationalPermitExpiry is string);
    }

    function isValidTaxRecord(data) {
      return data.keys().hasAll(['plateNumber', 'ownerName', 'phoneNumber', 'taxType', 'taxAmount', 'inDate', 'paidDate']) &&
             data.plateNumber is string && data.plateNumber.size() > 0 &&
             data.ownerName is string && data.ownerName.size() > 0 &&
             data.phoneNumber is string && data.phoneNumber.size() >= 10 &&
             data.taxType is string &&
             data.taxAmount is string &&
             data.inDate is string &&
             data.paidDate is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /vehicles/{vehicleId} {
      allow read, write: if true;
    }

    match /tax_records/{recordId} {
      allow read, write: if true;
    }

    match /settings/{settingId} {
      allow read, write: if true;
    }

    match /billing_records/{billId} {
      allow read, write: if true;
    }

    match /_connection_test_/{testId} {
      allow read: if true;
    }
  }
}
